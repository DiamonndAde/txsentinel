# Solana RPC (devnet default; use a mainnet RPC + NETWORK=mainnet-beta for mainnet)
RPC_URL="https://api.devnet.solana.com"
NETWORK=devnet

# Yellowstone gRPC (SolInfra or any Dragon's Mouth provider)
GRPC_URL="fra.grpc.solinfra.dev:443"
GRPC_X_TOKEN="<your gRPC x-token>"

# Jito Block Engine (bundle submission — mainnet only)
JITO_BLOCK_ENGINE_URL="https://mainnet.block-engine.jito.wtf"

# DeepSeek AI agent
DEEPSEEK_API_KEY=<your DeepSeek API key from platform.deepseek.com>
DEEPSEEK_MODEL=deepseek-chat   # or deepseek-reasoner for explicit chain-of-thought (slower)

# Wallet
KEYPAIR_PATH=~/.config/solana/id.json
